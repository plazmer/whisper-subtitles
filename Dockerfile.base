# Base image with all dependencies
FROM nvidia/cuda:12.1.0-runtime-ubuntu22.04

USER root

# Stage 1: System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    mkvtoolnix \
    aria2 \
    curl \
    python3 \
    python3-pip \
    python3-venv \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Stage 2: Upgrade pip
RUN pip3 install --no-cache-dir --upgrade pip

# Stage 3: Install PyTorch with CUDA (largest - ~4GB)
RUN pip3 install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cu121

# Stage 4: Install web framework dependencies
RUN pip3 install --no-cache-dir \
    fastapi==0.109.0 \
    uvicorn[standard]==0.27.0 \
    python-multipart==0.0.6 \
    aiosqlite==0.19.0 \
    httpx==0.26.0 \
    python-jose[cryptography]==3.3.0 \
    passlib==1.7.4 \
    bcrypt==4.0.1 \
    pydantic==2.5.3 \
    pydantic-settings==2.1.0 \
    aiofiles==23.2.1

# Stage 5: Install Whisper (with deps for consistency)
RUN pip3 install --no-cache-dir openai-whisper

# Stage 6: Install pyannote for speaker diarization
RUN pip3 install --no-cache-dir "pyannote.audio<4" "huggingface_hub>=0.20,<1.0"

# Stage 7: Align torchaudio with preinstalled torch (2.5.1+cu121)
RUN pip3 install --no-cache-dir --force-reinstall \
    torchaudio==2.5.1 \
    --no-deps \
    --index-url https://download.pytorch.org/whl/cu121

# Stage 8: Install audio libraries
RUN pip3 install --no-cache-dir \
    librosa>=0.10.0 \
    soundfile>=0.12.0 \
    numpy>=1.24.0

# Create data directories
RUN mkdir -p /app/data/uploads /app/data/downloads /app/data/temp /app/data/output /app/models/huggingface

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV HF_HOME=/app/models/huggingface

EXPOSE 8000

# Stage 9: Validation — verify all imports work
RUN python3 -c "\
import whisper; import pyannote.audio; import torch; \
print(f'torch={torch.__version__} cuda_build={torch.version.cuda}'); \
print('whisper OK'); print('pyannote OK')"

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
