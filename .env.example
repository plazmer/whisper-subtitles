# Whisper Subtitle Generator Configuration

# Secret key for JWT tokens (change in production!)
SECRET_KEY=change-me-in-production-use-a-long-random-string

# Default Whisper model (tiny, base, small, medium, large-v2, large-v3, large-v3-turbo)
DEFAULT_MODEL=large-v3

# Device for inference (cuda, cpu, or auto)
# cuda: Use NVIDIA GPU with CUDA (recommended if available)
# cpu: Force CPU only
# auto: Auto-detect (use CUDA if available, fallback to CPU)
DEVICE=auto
